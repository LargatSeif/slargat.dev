---
import { Icon } from "astro-icon/components"
import Section from "../Section.astro"
import { projects as projectsData } from "@cv"
import type { Projects } from "@/data/cv"
const projects = projectsData as unknown as Projects[]

// Map known entities to logo URLs (web SVG/PNG)
const logoMap = {
  "Veolia Water Technologies": "https://media.licdn.com/dms/image/v2/D4E0BAQGvx6kxOwdsCg/company-logo_100_100/B4EZfFKLCPG4AY-/0/1751359468112/veolia_water_tech_logo?e=1756944000&v=beta&t=6Ga3mABfhfxTqGYoNBMfjviZDoHMylR84Eiq8emBYHg",
  "Devoteam Creative Tech": "https://media.licdn.com/dms/image/v2/C560BAQGsn6Xeg-ZsLQ/company-logo_100_100/company-logo_100_100/0/1638346752697/axancebydevoteam_logo?e=1756944000&v=beta&t=5PKQj7TJqUl5uwp987EKSZrAivAKCjVJM8yYF0kOXwk",
  "Bunqer": "https://media.licdn.com/dms/image/v2/D560BAQGoH2KGvl8hFg/company-logo_100_100/company-logo_100_100/0/1729685720463/bunqertech_logo?e=1756944000&v=beta&t=Knpq4yD63uqZnQ6b7ddtvVbLj1zULFbBXioKARmDAEk",
  "ENGIE IT": "https://media.licdn.com/dms/image/v2/C560BAQEqETyMClT-Iw/company-logo_100_100/company-logo_100_100/0/1630597707536/engie_it_logo?e=1756944000&v=beta&t=-vx7RbHbK5Ffav4s7d-p8Bsi6ZXBoMHpXYwBE7gaeDc",
  "Zaion – Callbot & Chatbot": "https://media.licdn.com/dms/image/v2/C4E0BAQFOrI5pR1RtiA/company-logo_100_100/company-logo_100_100/0/1634634479271/zaion_callbot_logo?e=1756944000&v=beta&t=_D4cv3ngnSErP6_3mN9kpYHE29BMvkxhxI1JBjeuIjE",
  "Lookiimobile Tunisie": "https://media.licdn.com/dms/image/v2/C560BAQFxdROM3WVy2Q/company-logo_100_100/company-logo_100_100/0/1630620564892/lookiimobile_tunisie_logo?e=1756944000&v=beta&t=nmiNT6FMvJfPvQ-TsoDRg4XPjnZaEtHjpvlCDAWadpk",
  "Institut des Hautes Etudes Commerciales de Carthage": "https://upload.wikimedia.org/wikipedia/fr/2/2e/Logo_IHEC_Carthage.png"
}

function getLogo(entity: string) {
  return logoMap[entity as keyof typeof logoMap] || "/favicon.png";
}
---

<Section title="Projects">
  <div class="project-cards compact">
    {projects.map(({ name, entity, startDate, endDate, description, highlights = [] }) => {
      const logo = getLogo(entity || '');
      const start = startDate ? new Date(startDate).toLocaleString('en-US', { month: 'short', year: 'numeric' }) : '';
      const end = endDate ? new Date(endDate).toLocaleString('en-US', { month: 'short', year: 'numeric' }) : 'Present';
      return (
        <div class="project-card compact">
          <div class="project-logo compact">
            <img src={logo} alt={entity || name} loading="lazy" />
          </div>
          <div class="project-content compact">
            <div class="project-title compact">{name}</div>
            {entity && <div class="project-entity compact">{entity}</div>}
            <div class="project-dates compact">{start}{start && end ? ' – ' : ''}{end}</div>
            {description && <div class="project-description compact">{description}</div>}
            {highlights.length > 0 && (
              <ul class="project-highlights compact">
                {highlights.map(h => <li>{h}</li>)}
              </ul>
            )}
          </div>
        </div>
      )
    })}
  </div>
</Section>

<style>
.project-cards.compact {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}
.project-card.compact {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border: 1px solid #ededed;
  border-radius: 16px;
  padding: 1.1rem 1.5rem;
  gap: 1.1rem;
  box-shadow: none;
  transition: border 0.2s;
}
.project-card.compact:hover {
  border-color: #e0e0e0;
}
.project-logo.compact {
  flex: 0 0 38px;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  height: 38px;
  width: 38px;
  margin-right: 1rem;
}
.project-logo.compact img {
  max-width: 38px;
  max-height: 38px;
  border-radius: 7px;
  background: #f5f5f5;
  object-fit: contain;
}
.project-content.compact {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
}
.project-title.compact {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.1em;
}
.project-entity.compact {
  font-size: 0.92rem;
  color: #888;
  margin-bottom: 0.1em;
}
.project-dates.compact {
  font-size: 0.88rem;
  color: #888;
  margin-bottom: 0.2em;
}
.project-description.compact {
  font-size: 0.92rem;
  color: #444;
  margin-bottom: 0.3em;
}
.project-highlights.compact {
  margin: 0.2em 0 0 0;
  padding-left: 1.1em;
  color: #555;
  font-size: 0.92rem;
}
.project-highlights.compact li {
  margin-bottom: 0.1em;
}
@media (max-width: 700px) {
  .project-card.compact {
    flex-direction: column;
    align-items: flex-start;
    padding: 0.7rem 0.5rem;
    gap: 0.7rem;
  }
  .project-logo.compact {
    margin-right: 0;
    margin-bottom: 0.5rem;
  }
  .project-title.compact {
    font-size: 0.95rem;
  }
  .project-description.compact {
    font-size: 0.9rem;
  }
  .project-entity.compact, .project-highlights.compact, .project-dates.compact {
    font-size: 0.85rem;
  }
}
</style>
