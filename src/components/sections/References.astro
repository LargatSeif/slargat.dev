---
import Section from "../Section.astro"
import { references as referencesData } from "@cv"
import type { References } from "@/data/cv"
const references = referencesData as References[]

function capitalizeWords(str: string) {
  return str.replace(/\b\w/g, c => c.toUpperCase());
}
---

<Section title="References">
  <div class="references-list">
    {references.map(({ name, position, company, date, reference }) => (
      <div class="reference-card">
        <div class="reference-name">{capitalizeWords(name)}</div>
        {(position || company || date) && (
          <div class="reference-details volunteer-details">
            <div class="details-main">
              {position && <span>{position}</span>}
              {position && company && <span>, </span>}
              {company && <span>{company}</span>}
            </div>
            {date && (
              <div class="details-date">
                {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </div>
            )}
          </div>
        )}
        <div class="reference-text">{reference}</div>
      </div>
    ))}
  </div>
</Section>

<style>
.references-list {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}
.reference-card {
  background: #fff;
  border: 1px solid #ededed;
  border-radius: 14px;
  padding: 1.1rem 1.5rem;
  box-shadow: none;
  transition: border 0.2s;
}
.reference-card:hover {
  border-color: #e0e0e0;
}
.reference-name {
  font-size: 1rem;
  font-weight: 700;
  color: #222;
  margin-bottom: 0.1em;
  text-transform: capitalize;
}
.reference-details {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  font-size: 0.88rem;
  color: #888;
  font-style: italic;
  margin-bottom: 0.3em;
  line-height: 1.2;
  gap: 1em;
}
.details-main {
  flex: 1;
}
.details-date {
  white-space: nowrap;
  color: #aaa;
  font-style: normal;
  font-size: 0.85em;
}
.reference-text {
  font-size: 0.95rem;
  color: #444;
  white-space: pre-line;
}
@media (max-width: 700px) {
  .reference-card {
    padding: 0.7rem 0.5rem;
  }
  .reference-name {
    font-size: 0.95rem;
  }
  .reference-details {
    flex-direction: column;
    gap: 0.2em;
    font-size: 0.8rem;
  }
  .reference-text {
    font-size: 0.9rem;
  }
}
</style> 