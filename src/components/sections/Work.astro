---
import Section from "../Section.astro"
import { work as workData } from "@cv"
import type { Work } from "@/data/cv"

// Map known company names to logo URLs (same as Projects.astro)
const logoMap = {
  "Veolia Water Technologies": "https://media.licdn.com/dms/image/v2/D4E0BAQGvx6kxOwdsCg/company-logo_100_100/B4EZfFKLCPG4AY-/0/1751359468112/veolia_water_tech_logo?e=1756944000&v=beta&t=6Ga3mABfhfxTqGYoNBMfjviZDoHMylR84Eiq8emBYHg",
  "Devoteam Creative Tech": "https://media.licdn.com/dms/image/v2/C560BAQGsn6Xeg-ZsLQ/company-logo_100_100/company-logo_100_100/0/1638346752697/axancebydevoteam_logo?e=1756944000&v=beta&t=5PKQj7TJqUl5uwp987EKSZrAivAKCjVJM8yYF0kOXwk",
  "Devoteam": "https://media.licdn.com/dms/image/v2/C560BAQGsn6Xeg-ZsLQ/company-logo_100_100/company-logo_100_100/0/1638346752697/axancebydevoteam_logo?e=1756944000&v=beta&t=5PKQj7TJqUl5uwp987EKSZrAivAKCjVJM8yYF0kOXwk",
  "Bunqer": "https://media.licdn.com/dms/image/v2/D560BAQGoH2KGvl8hFg/company-logo_100_100/company-logo_100_100/0/1729685720463/bunqertech_logo?e=1756944000&v=beta&t=Knpq4yD63uqZnQ6b7ddtvVbLj1zULFbBXioKARmDAEk",
  "ENGIE IT": "https://media.licdn.com/dms/image/v2/C560BAQEqETyMClT-Iw/company-logo_100_100/company-logo_100_100/0/1630597707536/engie_it_logo?e=1756944000&v=beta&t=-vx7RbHbK5Ffav4s7d-p8Bsi6ZXBoMHpXYwBE7gaeDc",
  "Zaion – Callbot & Chatbot": "https://media.licdn.com/dms/image/v2/C4E0BAQFOrI5pR1RtiA/company-logo_100_100/company-logo_100_100/0/1634634479271/zaion_callbot_logo?e=1756944000&v=beta&t=_D4cv3ngnSErP6_3mN9kpYHE29BMvkxhxI1JBjeuIjE",
  "Lookiimobile Tunisie": "https://media.licdn.com/dms/image/v2/C560BAQFxdROM3WVy2Q/company-logo_100_100/company-logo_100_100/0/1630620564892/lookiimobile_tunisie_logo?e=1756944000&v=beta&t=nmiNT6FMvJfPvQ-TsoDRg4XPjnZaEtHjpvlCDAWadpk",
  "Institut des Hautes Etudes Commerciales de Carthage": "https://upload.wikimedia.org/wikipedia/fr/2/2e/Logo_IHEC_Carthage.png",
  "Air Liquide": "https://media.licdn.com/dms/image/v2/C510BAQF6PhVyWbLl5Q/company-logo_100_100/company-logo_100_100/0/1631349851629?e=1756944000&v=beta&t=fiXcJ3rsDk1UtBoLOtuDQtQVYtxjduM0zWambVXJbQc"
}
function getLogo(name: string) {
  return logoMap[name as keyof typeof logoMap] || "/favicon.png";
}

const work = workData as Work[]
---

<Section title="Work">
  <ul>
    {
      work.map(
        ({ name, startDate, endDate, position, summary, url="" }) => {
          const startDateObj = new Date(startDate)
          const endDateObj = endDate != null ? new Date(endDate) : null
          const startDateStr = startDateObj.toLocaleString('en-US', { month: 'short', year: 'numeric' })
          const endDateStr = endDateObj ? endDateObj.toLocaleString('en-US', { month: 'short', year: 'numeric' }) : "Present"
          const logo = getLogo(name)

          return (
            <li>
              <article class="work-article">
                <header class="work-header">
                  <div class="work-logo">
                    <img src={logo} alt={name} loading="lazy" />
                  </div>
                  <div class="work-main">
                    <h3>
                      <a href={url} title={`View ${name}`} target="_blank">
                        {name}
                      </a>
                    </h3>
                    <h4>{position}</h4>
                  </div>
                  <div class="work-dates">
                    <time 
                      datetime={startDate}
                      data-title={startDate}>
                        {startDateStr}
                    </time>
                    {" - "}
                    <time 
                      datetime={endDate}
                      data-title={endDate}>
                        {endDateStr}
                    </time>
                  </div>
                </header>
                <footer>
                  <p>{summary}</p>
                </footer>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .work-article {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .work-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .work-logo {
    flex: 0 0 38px;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .work-logo img {
    max-width: 38px;
    max-height: 38px;
    border-radius: 7px;
    background: #f5f5f5;
    object-fit: contain;
  }

  .work-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .work-main h3 {
    font-weight: 500;
    color: #111;
    font-size: 1rem;
    margin: 0;
  }

  .work-main h4 {
    color: #222;
    font-weight: 400;
    font-size: 0.92rem;
    margin: 0.1em 0 0 0;
  }

  .work-dates {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
    text-align: right;
    margin-left: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  footer p {
    color: #666;
    font-size: 0.9rem;
    margin: 0;
  }

  @media (width <= 700px) {
    .work-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .work-dates {
      text-align: left;
      align-items: flex-start;
      margin-left: 0;
      font-size: 0.82rem;
    }
  }
</style>
