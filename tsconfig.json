{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@cv": [
        "src/data/cv.json"
      ],
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "./worker-configuration.d.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.astro"
  ]
}